<component>
	<previews>
		<preview width="320" height="240" style_bg_color="0xeee" />
	</previews>

	<api>
		<!-- Add your API here here. For example 
		<prop name="prop1" type="int" default="0" help="What is this property?"/>
		-->
		<prop name="title" type="string" default="Title" />
	</api>

	<styles>
		<style
			name="style_base"
			width="100%"
			height="70"
			text_font="NS_Medium_32"
			layout="flex"
			flex_cross_place="center"
			flex_track_place="center"
			pad_hor="40"
		/>
	</styles>

	<view extends="lv_obj">
		<remove_style_all />
		<style name="style_base" />

		<lv_label text="$title" flex_grow="1" />
	</view>
</component>
